# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Opcional: Supabase Service Role (apenas para seed/scripts server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Opcional: string de conexão Postgres para automação do schema/seed (npm run db:init)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Opcional: desative SSL apenas em banco local
SUPABASE_DB_SSL=true
